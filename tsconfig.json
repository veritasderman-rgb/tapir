{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@tapir/core": ["simulation-core/src"],
      "@tapir/core/*": ["simulation-core/src/*"]
    }
  },
  "references": [
    { "path": "./simulation-core" },
    { "path": "./web-ui" }
  ]
}
